{
    "chat.mcp.serverSampling": {
        "about/.vscode/mcp.json: io.github.github/github-mcp-server": {
            "allowedModels": [
                "copilotcli/auto",
                "copilot/auto"
            ]
        }
    },
    "github.copilot.chat.claudeAgent.allowAutoPermissions": true,
    "github.copilot.chat.claudeAgent.useSdkExtension": true,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
    "github.copilot.chat.alternateGptPrompt.enabled": true,
    "github.copilot.chat.completionsFetcher": "node-fetch",
    "github.copilot.completions.chat.enabled": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "npm-intellisense.showBuildInLibs": true,
    "npm-intellisense.scanDevDependencies": true,
    "npm.enableRunFromFolder": true,
    "microsoft-sovereign-cloud.environment": "USGovernment",
    "merge-conflict.autoNavigateNextConflict.enabled": true,
    "jsts-chat-features.skills.enabled": true,
    "githubIssues.alwaysPromptForNewIssueRepo": true,
    "githubPullRequests.assignCreated": "${user}",
    "githubPullRequests.createOnPublishBranch": "always",
    "githubPullRequests.deleteBranchAfterMerge": true,
    "githubPullRequests.devMode": true,
    "CCA.claude.model": "sonnet",
    "CCA.claude.useWebSearch": true,
    "CCA.codex.model": "gpt-5.1-codex-mini",
    "CCA.codex.useWebSearch": true,
    "CCA.gemini.model": "gemini-2.5-flash",
    "github.copilot.chat.agent.autoFix": true,
    "github.copilot.chat.useProjectTemplates": true,
    "github.copilot.enable": {
        "scminput": true,
        "markdown": true
    },
    "github.copilot.selectedCompletionModel": "sonnets",
    "github-actions.workflows.pinned.refresh.enabled": true,
    "git.allowForcePush": false,
    "git.alwaysSignOff": true,
    "git.autofetch": true,
    "git.rememberPostCommitCommand": true,
    "git.pullBeforeCheckout": true,
    "git.openAfterClone": "always",
    "git.ignoreWindowsGit27Warning": true,
    "git.ignoreLegacyWarning": true,
    "git.ignoredRepositories": [
        ".vscode/*",
        "!.vscode/settings.json",
        "!.vscode/tasks.json",
        "!.vscode/launch.json",
        "!.vscode/extensions.json",
        "*.code-workspace",
        ".history/",
        "*.app",
        ".snapshots/*",
        "secring.*",
        "*~",
        ".fuse_hidden*",
        ".directory",
        ".Trash-*",
        ".nfs*",
        "nohup.out",
        "$RECYCLE.BIN/",
        "[Dd]esktop.ini"
    ],
    "git.followTagsWhenSync": true,
    "git.fetchOnPull": true,
    "git.enableSmartCommit": true,
    "git.enableCommitSigning": true,
    "telemetry.editStats.details.enabled": true,
    "telemetry.editStats.showDecorations": true,
    "telemetry.editStats.showStatusBar": true,
    "extensions.closeExtensionDetailsOnViewChange": true,
    "extensions.supportNodeGlobalNavigator": true,
    "extensions.allowOpenInModalEditor": true,
    "scm.alwaysShowActions": true,
    "scm.alwaysShowRepositories": true,
    "issueReporter.experimental.webReporter": true,
    "remote.localPortHost": "allInterfaces",
    "chat.checkpoints.showFileChanges": true,
    "chat.agent.sandbox.allowNetwork": true,
    "chat.agent.sandbox.enabled": "on",
    "chat.agent.sandbox.enabledWindows": "on",
    "chat.editing.autoAcceptDelay": 3,
    "chat.agent.networkFilter": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    },
    "chat.mcp.gallery.enabled": true,
    "chat.mcp.assisted.nuget.enabled": true,
    "inlineChat.notebookAgent": true,
    "inlineChat.affordance": "editor",
    "workbench.editor.alwaysShowEditorActions": true,
    "workbench.editor.autoLockGroups": {
        "vscode.markdown.editor": true,
        "default": true,
        "agentSessionsWelcomePage": true,
        "jupyter-notebook": true,
        "mainThreadWebview-markdown.preview": true
    },
    "workbench.editor.centeredLayoutFixedWidth": true,
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.defaultBinaryEditor": "default",
    "workbench.editor.labelFormat": "long",
    "workbench.settings.alwaysShowAdvancedSettings": true,
    "editor.find.autoFindInSelection": "multiline",
    "editor.formatOnSaveMode": "modifications",
    "editor.formatOnSave": true,
    "diffEditor.codeLens": true,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.inlineSuggest.suppressInSnippetMode": false,
    "files.autoGuessEncoding": true,
    "files.autoSaveWorkspaceFilesOnly": true,
    "files.defaultLanguage": "${activeEditorLanguage",
    "DockerRun.DisableDockerrc": true,
    "DockerRun.Containers": [
        "a52f319dde15"
    ]
}